{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl",
            "args": [
              "-sS", "--max-time", "30", "-X", "POST",
              "http://localhost:4003/api/hooks/session-start",
              "-H", "Content-Type: application/json",
              "-H", "X-Working-Dir: ${CLAUDE_PROJECT_DIR}",
              "--data-binary", "@-"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
