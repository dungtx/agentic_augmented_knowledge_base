          {
            "type": "command",
            "command": "curl",
            "args": [
              "-sS", "-X", "POST",
              "http://localhost:4003/api/permissions/request",
              "-H", "Content-Type: application/json",
              "-H", "X-Working-Dir: ${CLAUDE_PROJECT_DIR}",
