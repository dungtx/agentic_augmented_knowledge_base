#!/bin/bash
# Claude Code PermissionRequest hook.
# Forwards the hook payload on stdin to the local cms server, which long-polls
# until the user decides (or times out) and returns the Claude Code hook
# response directly. On any failure the ASK fallback lets Claude Code fall
# back to its built-in prompt.
ASK='{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"ask"}}}'

curl -sf -X POST "http://localhost:${CODEMYSPEC_PORT:-4003}/api/permissions/request" \
  -H "Content-Type: application/json" \
  -H "X-Working-Dir: $PWD" \
  --data-binary @- 2>/dev/null || echo "$ASK"
